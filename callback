<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>CloudPy — Logging in...</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
<style>
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:#060810;color:#e2e8f0;font-family:'JetBrains Mono',monospace;min-height:100vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px;}
  body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,255,136,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,136,0.025) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;}
  .logo{width:56px;height:56px;background:linear-gradient(135deg,#00ff88,#3b82f6);border-radius:14px;display:flex;align-items:center;justify-content:center;font-family:'Orbitron',sans-serif;font-size:24px;font-weight:900;color:#000;box-shadow:0 0 28px rgba(0,255,136,0.4);margin-bottom:8px;}
  .title{font-family:'Orbitron',sans-serif;font-size:18px;font-weight:900;color:#00ff88;}
  .msg{font-size:13px;color:#64748b;margin-top:4px;}
  .dots::after{content:'';animation:dots 1.5s infinite;}
  @keyframes dots{0%{content:''}33%{content:'.'}66%{content:'..'}100%{content:'...'}}
  .err{color:#ff4444;font-size:13px;margin-top:16px;background:rgba(255,68,68,0.08);border:1px solid rgba(255,68,68,0.2);border-radius:8px;padding:12px 20px;max-width:400px;text-align:center;}
</style>
</head>
<body>
<div class="logo">C</div>
<div class="title">CLOUDPY</div>
<div class="msg">Authenticating with Discord<span class="dots"></span></div>
<div class="err" id="errBox" style="display:none;"></div>

<script>
(async () => {
  const params  = new URLSearchParams(window.location.search);
  const code    = params.get('code');
  const backend = localStorage.getItem('cloudpy_backend') || '';

  if (!code) {
    showErr('No auth code received. <a href="index.html" style="color:#00ff88;">Go back</a>');
    return;
  }
  if (!backend) {
    showErr('Backend URL not set. <a href="index.html" style="color:#00ff88;">Go back</a> and set it first.');
    return;
  }

  const redirectUri = window.location.origin + window.location.pathname;

  try {
    const res = await fetch(backend + '/api/auth/discord', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code, redirectUri })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Auth failed');

    sessionStorage.setItem('cloudpy_token', data.token);
    sessionStorage.setItem('cloudpy_user', JSON.stringify(data.user));
    window.location.href = 'dashboard.html';
  } catch (e) {
    showErr('Login failed: ' + e.message + '<br><a href="index.html" style="color:#00ff88;">Try again</a>');
  }
})();

function showErr(html) {
  const box = document.getElementById('errBox');
  box.innerHTML = html;
  box.style.display = 'block';
}
</script>
</body>
</html>
